# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.*.local

# Wrangler / Cloudflare
.wrangler/
wrangler.toml
.dev.vars

# Build outputs
dist/
build/
*.tgz

# Exception: the vendored @cloudflare/dofs package IS its built dist (the
# upstream package is unpublished/private). It must be committed so the
# `file:./vendor/dofs` dependency resolves on a fresh clone.
!vendor/dofs/dist/
!vendor/dofs/dist/**

# TypeScript
*.tsbuildinfo

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
